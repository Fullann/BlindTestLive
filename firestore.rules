rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isValidTrack(track) {
      return track is map &&
             track.keys().hasAll(['id', 'title', 'artist']) &&
             track.keys().hasOnly(['id', 'title', 'artist', 'url', 'mediaType', 'mediaUrl', 'textContent', 'duration']) &&
             track.id is string && track.id.size() < 100 &&
             track.title is string && track.title.size() < 200 &&
             track.artist is string && track.artist.size() < 200 &&
             (!('url' in track) || (track.url is string && track.url.size() < 1000)) &&
             (!('mediaType' in track) || (track.mediaType is string && track.mediaType.size() < 50)) &&
             (!('mediaUrl' in track) || (track.mediaUrl is string && track.mediaUrl.size() < 1000)) &&
             (!('textContent' in track) || (track.textContent is string && track.textContent.size() < 2000)) &&
             (!('duration' in track) || (track.duration is number && track.duration > 0 && track.duration <= 3600));
    }

    function isValidPlaylist() {
      return hasOnlyAllowedFields(['name', 'ownerId', 'tracks', 'createdAt']) &&
             request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100 &&
             request.resource.data.ownerId is string &&
             request.resource.data.tracks is list && request.resource.data.tracks.size() <= 100 &&
             request.resource.data.createdAt is number;
    }

    match /playlists/{playlistId} {
      allow read: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthenticated() &&
                    request.resource.data.ownerId == request.auth.uid &&
                    isValidPlaylist();
      allow update: if isAuthenticated() &&
                    resource.data.ownerId == request.auth.uid &&
                    request.resource.data.ownerId == resource.data.ownerId &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    isValidPlaylist();
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
  }
}
