{
  "entities": {
    "Playlist": {
      "title": "Playlist",
      "description": "A collection of tracks for a Blind Test game.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the playlist."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who created the playlist."
        },
        "tracks": {
          "type": "array",
          "description": "The list of tracks in the playlist.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "artist": { "type": "string" },
              "url": { "type": "string" }
            },
            "required": ["id", "title", "artist"]
          }
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of creation."
        }
      },
      "required": ["name", "ownerId", "tracks", "createdAt"]
    }
  },
  "firestore": {
    "playlists/{playlistId}": {
      "schema": { "$ref": "Playlist" },
      "description": "Playlists created by admins."
    }
  }
}
